{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@repo/backend/action-plans": ["packages/backend/action-plans/src/index.ts"],
      "@repo/backend/actions": ["packages/backend/actions/src/index.ts"],
      "@repo/backend/kernel": ["packages/backend/kernel/src/index.ts"],
      "@repo/backend/kernel/*": ["packages/backend/kernel/src/*"],
      "@repo/backend/organizations": ["packages/backend/organizations/src/index.ts"],
      "@repo/backend/shared": ["packages/backend/shared/src/index.ts"],
      "@repo/backend/testing": ["packages/backend/testing/src/index.ts"]
    }
  }
}
