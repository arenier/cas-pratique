{
  "name": "backend-testing",
  "projectType": "library",
  "root": "packages/backend/testing",
  "sourceRoot": "packages/backend/testing/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check --diagnostic-level=warn packages/backend/testing"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "configFile": "packages/backend/testing/vitest.config.ts"
      }
    }
  }
}
